# AgentBox egress/credential broker secrets.
#
# Copy to ~/.agentbox/broker/secrets.env (agentbox --broker does this for
# you on first run, with mode 600). Loaded into the proxy sidecar's
# environment via --env-file - never baked into any image, never mounted
# into the agent container.
#
# Referenced from config.yaml via `value_env: <NAME>`. Rotating a value
# here requires a proxy restart (agentbox --broker will restart the
# sidecar); for live rotation without a restart, use `value_file`
# instead (see the commented example in config.example.yaml).

GH_BROKER_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
